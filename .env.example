# =========================
# Backend required
# =========================
# LLM provider key (required in non-test environments)
DASHSCOPE_API_KEY=your_dashscope_api_key
# Default model
MODEL_NAME=qwen-plus
# Compatible API base
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# =========================
# Backend optional capabilities
# =========================
# Required only when web search tool is enabled
TAVILY_API_KEY=your_tavily_api_key
# Optional persistent memory storage
POSTGRES_URL=postgresql://username:password@localhost:5432/studymate
# Optional context cache
REDIS_URL=redis://localhost:6379/0
# Context history window size
MEMORY_CONTEXT_WINDOW=12
# Context cache TTL (seconds)
MEMORY_CONTEXT_TTL_SECONDS=1800
# Business chat history query limit
BUSINESS_CHAT_HISTORY_LIMIT=100
# Auth secret for access / refresh tokens
AUTH_SECRET_KEY=change-me-in-production
# Access token TTL in seconds
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# Refresh token TTL in seconds
AUTH_REFRESH_TOKEN_TTL_SECONDS=1209600
# Task broker backend: inmemory | kafka
TASK_BROKER_BACKEND=inmemory
# Required when TASK_BROKER_BACKEND=kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Kafka topic used by chat task jobs
KAFKA_CHAT_TASK_TOPIC=chat.request
# Kafka consumer group used by standalone worker
KAFKA_CHAT_TASK_CONSUMER_GROUP=studymate-chat-worker

# =========================
# Frontend (Vite)
# =========================
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT=60000
VITE_CHAT_ENDPOINT=/chat/agent
